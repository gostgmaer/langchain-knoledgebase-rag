# ============================================================
# langchain-knoledgebase-rag — Environment Configuration
# ============================================================
# Every variable below is read by a real pydantic-settings class
# under packages/config/*.py — this file is generated from those
# classes, not from a template. Copy to `.env` and fill in real
# values; `.env` is gitignored and must never be committed.
#
# Vars marked "Required" have no Python default — the app will
# fail to start (or fail on first use) without them. Everything
# else has a sensible default and only needs setting if you want
# to override it.
# ============================================================

##############################################################
# Application — packages/config/app.py (AppSettings)
##############################################################
APP_NAME=EasyDev AI Platform
APP_VERSION=1.0.0
APP_ENV=development                  # development | test | staging | production
DEBUG=false

##############################################################
# API server — packages/config/api.py (APISettings)
##############################################################
HOST=0.0.0.0
PORT=8000

# Origins allowed to call this API cross-origin — the frontend/
# Next.js app (a different port, so a different origin) needs this
# to make any browser fetch work at all. Comma-separated.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# The fields below (docs_url/redoc_url/openapi_url/api_prefix)
# exist on APISettings but are NOT currently read by
# packages/api/app.py (it hardcodes /docs, /redoc, /openapi.json).
# Setting these has no effect yet — see docs/BUILD_STATUS.md.
# DOCS_URL=/docs
# REDOC_URL=/redoc
# OPENAPI_URL=/openapi.json
# API_PREFIX=/api/v1

##############################################################
# Database — packages/config/database.py (DatabaseSettings)
##############################################################
# Required. Async SQLAlchemy connection string (Postgres + asyncpg).
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# Required only when running Postgres via docker-compose.yml — the official
# postgres/pgvector image reads these three to initialize itself on first
# boot, and docker-compose.yml's healthcheck also references POSTGRES_USER.
# Keep them consistent with DATABASE_URL above.
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=dbname

# Optional overrides (defaults shown):
# POOL_SIZE=10
# MAX_OVERFLOW=20
# POOL_TIMEOUT=30
# ECHO=false

##############################################################
# Redis — packages/config/redis.py (RedisSettings)
##############################################################
# Required.
REDIS_URL=redis://localhost:6379/0

# DEFAULT_TTL=3600

##############################################################
# AI / LLM providers — packages/config/ai.py (AISettings)
##############################################################
LLM_PROVIDER=google                  # google | openai | anthropic | groq
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192
LLM_STREAMING=true

# Set at least the key matching LLM_PROVIDER above.
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

##############################################################
# RAG / retrieval — packages/config/rag.py (RAGSettings)
##############################################################
EMBEDDING_PROVIDER=google             # google | openai | huggingface
EMBEDDING_MODEL=models/embedding-001
VECTOR_STORE_BACKEND=chroma           # chroma | pgvector — faiss/qdrant are NOT implemented yet (docs/BUILD_STATUS.md, gap #8)
VECTOR_COLLECTION_NAME=langchain
CHROMA_DIRECTORY=./storage/chroma
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

##############################################################
# Feature flags — packages/config/features.py (FeatureSettings)
##############################################################
ENABLE_RAG=true
ENABLE_TOOLS=true
ENABLE_MEMORY=true
ENABLE_STREAMING=true
ENABLE_RERANKING=true
ENABLE_QUERY_REWRITE=true
ENABLE_WEB_SEARCH=true
ENABLE_WEATHER=true
ENABLE_NEWS=true
ENABLE_CALCULATOR=true
# Master kill-switch for real RBAC enforcement — see packages/config/features.py
# and packages/api/dependencies.py's require_permission()/require_role().
ENABLE_RBAC=false

##############################################################
# Search / Weather / News tools — packages/tools/builtin/*.py
##############################################################
# Read directly via os.getenv() in the tool modules, not through
# a pydantic settings class — still required for Tools to work.
SERPER_API_KEY=
TAVILY_API_KEY=
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5/weather
NEWSAPI_API_KEY=
NEWSAPI_BASE_URL=https://newsapi.org/v2

##############################################################
# Security / JWT — packages/config/security.py (SecuritySettings)
##############################################################
# Required. Signing secret — note JWT verification is not yet
# enforced by any middleware (docs/BUILD_STATUS.md, Phase 2),
# but SecuritySettings still requires this to construct.
JWT_SECRET=
JWT_ALGORITHM=HS256

##############################################################
# Queue — packages/config/queue.py (QueueSettings)
##############################################################
QUEUE_PREFIX=easydev

# Optional overrides (defaults shown):
# CONCURRENCY=5
# MAX_RETRIES=3
# RETRY_DELAY=5

##############################################################
# Storage — packages/config/storage.py (StorageSettings)
##############################################################
# No required vars. Optional overrides (defaults shown):
# PROVIDER=local                      # local | s3 | azure | minio
# UPLOAD_DIRECTORY=storage/uploads
# TEMP_DIRECTORY=storage/temp
# MAX_FILE_SIZE=52428800
# SIGNED_URL_EXPIRY=3600

##############################################################
# Logging — packages/config/logging.py (LoggingSettings)
##############################################################
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=false

##############################################################
# Upload service — packages/config/upload_service.py (UploadServiceSettings)
##############################################################
# Required. Base URL of the EasyDev Upload Service (NOT LangSmith —
# a real .env in this repo previously had this set to LangSmith's
# URL by copy-paste mistake; double-check this value).
UPLOAD_SERVICE_URL=http://localhost:4000
UPLOAD_SERVICE_TIMEOUT=30
UPLOAD_SERVICE_API_KEY=
UPLOAD_SIGNED_URL_EXPIRY=3600
UPLOAD_SERVICE_VERIFY_SSL=true

##############################################################
# IAM — packages/config/iam.py (IAMSettings, env_prefix="IAM_")
##############################################################
# All four of these are Required — packages/config/loader.py's
# get_settings() constructs IAMSettings() eagerly at import time,
# so a missing value here crashes the whole app at startup, not
# just on first use.
# IAM_BASE_URL should be your gateway's base host, not the IAM service
# directly — the gateway routes by resource-group prefix (/api/auth/*,
# /api/users/*, /api/tenants/*, /api/iam/* as the catch-all, e.g. for
# /health) rather than one consistent prefix. See packages/sdk/iam/
# endpoints.py for the full, live-confirmed mapping.
IAM_BASE_URL=http://localhost:3000
# JWKS isn't reachable through most gateways — only needed if you
# verify RS256 JWTs locally instead of via /auth/me.
IAM_JWKS_BASE_URL=
IAM_CLIENT_ID=
IAM_CLIENT_SECRET=
IAM_INTROSPECTION_API_KEY=

IAM_TIMEOUT=30
IAM_VERIFY_SSL=true
IAM_MAX_RETRIES=3

##############################################################
# Notification — packages/config/notification.py (NotificationSettings)
##############################################################
# NOT currently wired into packages/config/settings.py's Settings
# aggregator or instantiated anywhere in the app (sdk/notification/
# is unused dead code as of this writing) — setting these has no
# effect yet. Left here so the class's env contract is documented
# for whenever it gets wired up.
# NOTIFICATION_BASE_URL=
# NOTIFICATION_API_KEY=
# NOTIFICATION_TIMEOUT=30
# NOTIFICATION_VERIFY_SSL=true
